{
  "projectType": "sdk-library",
  "projectName": "okfetch",
  "projectDescription": "A lightweight, type-safe family of TypeScript HTTP packages that wraps the native fetch API with Zod validation, Result-based error handling, retries, auth, plugins, and a typed API client generator.",
  "theme": "palm",
  "primaryColor": "#040404",
  "lightColor": null,
  "darkColor": null,
