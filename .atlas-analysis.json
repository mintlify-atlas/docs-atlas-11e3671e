  "keyFeatures": [
    "Result-based error handling via better-result — no thrown exceptions for expected HTTP failures",
    "Zod-powered response and request validation (body, params, query, output)",
    "Plugin lifecycle hooks: init, onRequest, onResponse, onSuccess, onFail, onRetry",
    "Built-in retry strategies: fixed, linear, exponential",
    "Auth helpers: bearer, basic, and custom prefix",
    "SSE-style streaming with per-chunk Zod validation",
    "Typed API client generator from schema-defined endpoint trees (@okfetch/api)",
    "pino-based logging plugin (@okfetch/logger)"
  ],
  "publicApiSurface": [
    "okfetch(url, options) — @okfetch/fetch",
    "validateClientErrors — @okfetch/fetch",
    "validateAllErrors — @okfetch/fetch",
    "FetchError, TimeoutError, ApiError, ParseError, ValidationError, PluginError — @okfetch/fetch",
    "OkfetchOptions, OkfetchPlugin, OkfetchPluginHooks, Auth, RetryOptions — @okfetch/fetch",
    "createEndpoints(tree) — @okfetch/api",
    "createApi(options) — @okfetch/api",
    "ApiService(endpoints) — @okfetch/api",
    "Endpoint, EndpointTree, EndpointCallOptions, ApiClient, ApiErrors — @okfetch/api",
    "logger(options?) — @okfetch/logger"
  ]
}
